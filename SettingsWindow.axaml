<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="minesweepy.SettingsWindow"
        Title="Settings"
        Width="450"
        Height="450"
        >

    <StackPanel Background="DimGray">
        <TextBox x:Name="RowBox" PlaceholderText="Row amount" Background="SlateGray"
                 HorizontalAlignment="Center"/>
        <TextBox x:Name="ColumnBox" PlaceholderText="Column amount" Background="SlateGray"
                 HorizontalAlignment="Center"/>
        <TextBox x:Name="MineBox" PlaceholderText="Mine percentage, defaults to 12% of cells" Background="SlateGray"
                 HorizontalAlignment="Center"/>
        <Button Content="- Start Custom Game -" Background="SlateGray"
                HorizontalAlignment="Center"
                FontSize="20"
                Click="NewGame_Click"/>
        
        <Separator Background="Black"></Separator>
    </StackPanel>

</Window>
