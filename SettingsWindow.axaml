<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="minesweepy.SettingsWindow"
        Title="Settings"
        Width="450"
        Height="450"
        >

    <StackPanel Background="DimGray">
        <TextBox x:Name="RowBox" PlaceholderText="Row amount" Background="LightSlateGray"
                 HorizontalAlignment="Center"/>
        <TextBox x:Name="ColumnBox" PlaceholderText="Column amount" Background="LightSlateGray"
                 HorizontalAlignment="Center"/>
        <TextBox x:Name="MineBox" PlaceholderText="Mine amount, defaults to 15% of cells" Background="LightSlateGray"
                 HorizontalAlignment="Center"/>
        <Button Content="* Start New Game *" Background="LightSlateGray"
                HorizontalAlignment="Center"
                FontSize="20"
                Click="NewGame_Click"/>
    </StackPanel>

</Window>
