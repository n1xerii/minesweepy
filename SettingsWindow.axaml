<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="minesweepy.SettingsWindow"
        Width="450"
        Height="450"
        Title="Settings">

    <StackPanel Background="DimGray">
        <TextBox PlaceholderText="Row amount." Background="LightSlateGray"
                 HorizontalAlignment="Center"/>
        <TextBox PlaceholderText="Column amount." Background="LightSlateGray"
                 HorizontalAlignment="Center"/>
        <TextBox PlaceholderText="Mine amount." Background="LightSlateGray"
                 HorizontalAlignment="Center"/>
        <Button Content="* Start New Game *" Background="LightSlateGray"
                HorizontalAlignment="Center"
                FontSize="20"/>
    </StackPanel>

</Window>
